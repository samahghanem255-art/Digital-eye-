<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Digital Eye</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050a0f;--bg2:#080f18;--surf:#0d1821;--surf2:#111d2b;
  --bd:rgba(0,180,255,0.13);--acc:#00b4ff;--acc2:#ff3c6e;--acc3:#00ffd5;
  --tx:#e8f4ff;--tx2:#8ba8c0;--tx3:#4a6a85;--glow:rgba(0,180,255,0.25);
}
[data-theme="light"]{
  --bg:#f0f5fa;--bg2:#e4edf6;--surf:#fff;--surf2:#f5f9fd;
  --bd:rgba(0,100,200,0.12);--tx:#0d1821;--tx2:#3a5a7a;--tx3:#7a9ab8;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:'Cairo',sans-serif;min-height:100vh;overflow-x:hidden;transition:background .4s,color .4s}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--acc);border-radius:3px}

/* TOPBAR */
.topbar{background:var(--bg2);border-bottom:1px solid var(--bd);padding:7px 28px;display:flex;align-items:center;gap:14px;font-size:12px;color:var(--tx3)}
.ticker-wrap{flex:1;overflow:hidden}
.ticker{display:inline-block;white-space:nowrap;animation:tick 32s linear infinite;color:var(--acc);font-size:12px}
.ticker span{margin:0 30px}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* NAVBAR */
.navbar{position:sticky;top:0;z-index:999;background:rgba(5,10,15,0.94);backdrop-filter:blur(18px);border-bottom:1px solid var(--bd);padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:64px;transition:background .4s}
[data-theme="light"] .navbar{background:rgba(240,245,250,0.96)}
.logo-area{display:flex;align-items:center;gap:10px;text-decoration:none;cursor:pointer}
.logo-img{width:40px;height:40px;border-radius:50%;border:2px solid var(--acc);box-shadow:0 0 14px var(--glow);object-fit:cover}
.logo-name{font-size:19px;font-weight:700;color:var(--tx);letter-spacing:2px;font-family:'Rajdhani',sans-serif}
.logo-name span{color:var(--acc)}
.nav-links{display:flex;gap:2px;list-style:none}
.nav-links a{color:var(--tx2);text-decoration:none;font-size:13px;font-weight:600;padding:7px 13px;border-radius:8px;transition:.3s;cursor:pointer}
.nav-links a:hover,.nav-links a.on{color:var(--acc);background:rgba(0,180,255,0.08)}
.nav-ctrl{display:flex;align-items:center;gap:8px}
.lang-sw{display:flex;background:var(--surf);border:1px solid var(--bd);border-radius:24px;padding:3px;gap:2px}
.lb{background:none;border:none;color:var(--tx3);font-size:10px;font-weight:700;padding:4px 9px;border-radius:16px;cursor:pointer;transition:.3s;letter-spacing:1px;font-family:'Rajdhani',sans-serif}
.lb.on{background:var(--acc);color:#000}
.lb:hover:not(.on){color:var(--tx);background:var(--surf2)}
.theme-btn{background:var(--surf);border:1px solid var(--bd);border-radius:24px;padding:6px 12px;cursor:pointer;font-size:12px;color:var(--tx2);transition:.3s}
.theme-btn:hover{border-color:var(--acc);color:var(--acc)}
.call-btn{background:linear-gradient(135deg,var(--acc),#0060cc);border:none;color:#fff;font-weight:700;font-size:12px;padding:9px 18px;border-radius:24px;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:6px;box-shadow:0 3px 16px var(--glow);transition:.3s}
.call-btn:hover{transform:translateY(-2px);box-shadow:0 6px 24px var(--glow)}

/* BREAKING */
.breaking{background:linear-gradient(90deg,#cc0033,var(--acc2));padding:10px 28px;display:flex;align-items:center;gap:14px;overflow:hidden}
.brk-tag{background:rgba(255,255,255,0.2);color:#fff;font-weight:900;font-size:10px;padding:3px 10px;border-radius:4px;white-space:nowrap;letter-spacing:2px;animation:bl 1.5s step-end infinite}
@keyframes bl{50%{opacity:.5}}
.brk-txt{color:#fff;font-size:13px;font-weight:600;white-space:nowrap;animation:tick 22s linear infinite}

/* PAGES */
.page{display:none}.page.active{display:block}

/* HERO */
.hero{position:relative;min-height:90vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;overflow:hidden;padding:60px 28px 50px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(0,180,255,0.1),transparent 70%),radial-gradient(ellipse 40% 40% at 80% 80%,rgba(255,60,110,0.07),transparent 60%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,180,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,180,255,0.04) 1px,transparent 1px);background-size:55px 55px}
.hero-rings{position:relative;display:flex;align-items:center;justify-content:center;margin-bottom:24px;width:160px;height:160px}
.ring{position:absolute;border-radius:50%;border:1px solid rgba(0,180,255,0.2);animation:rp 3s ease-in-out infinite}
.ring:nth-child(1){width:100%;height:100%}
.ring:nth-child(2){width:130%;height:130%;border-color:rgba(0,180,255,0.1);animation-delay:.5s}
@keyframes rp{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.08);opacity:.5}}
.logo{width:100px;height:100px;border-radius:50%;border:2px solid var(--acc);box-shadow:0 0 30px var(--glow);object-fit:cover;position:absolute;animation:lf 4s ease-in-out infinite}
@keyframes lf{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.h1{font-size:clamp(42px,7vw,88px);font-weight:700;letter-spacing:5px;color:var(--tx);font-family:'Rajdhani',sans-serif;line-height:1;position:relative}
.h1 span{color:var(--acc)}
.h-sub{font-size:clamp(16px,2vw,22px);color:var(--tx2);margin:14px 0 8px;font-weight:300;letter-spacing:2px;position:relative}
.h-tag{font-size:12px;color:var(--acc3);letter-spacing:4px;text-transform:uppercase;margin-bottom:36px;font-family:'Rajdhani',sans-serif;position:relative}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative}
.btn-p{background:linear-gradient(135deg,var(--acc),#0055aa);color:#fff;border:none;font-family:'Cairo',sans-serif;font-weight:700;font-size:14px;padding:13px 28px;border-radius:32px;cursor:pointer;box-shadow:0 5px 24px var(--glow);transition:.3s;display:flex;align-items:center;gap:7px}
.btn-p:hover{transform:translateY(-3px);box-shadow:0 9px 36px var(--glow)}
.btn-s{background:transparent;color:var(--tx);border:1px solid var(--bd);font-family:'Cairo',sans-serif;font-weight:600;font-size:14px;padding:13px 28px;border-radius:32px;cursor:pointer;transition:.3s;display:flex;align-items:center;gap:7px}
.btn-s:hover{border-color:var(--acc);color:var(--acc);transform:translateY(-3px)}

/* STATS */
.stats-bar{background:linear-gradient(135deg,var(--surf),var(--surf2));border-top:1px solid var(--bd);border-bottom:1px solid var(--bd);padding:40px 28px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:center}
.sn{font-family:'Rajdhani',sans-serif;font-size:44px;font-weight:700;color:var(--acc);line-height:1;margin-bottom:6px}
.sl{font-size:12px;color:var(--tx2);font-weight:600}

/* SECTIONS */
.sec{padding:60px 28px}
.sec-hd{text-align:center;margin-bottom:40px}
.sec-lbl{font-family:'Rajdhani',sans-serif;font-size:10px;letter-spacing:4px;color:var(--acc);text-transform:uppercase;margin-bottom:10px;display:block}
.sec-title{font-size:clamp(22px,3vw,34px);font-weight:700;color:var(--tx);margin-bottom:12px}
.sec-line{width:50px;height:3px;background:linear-gradient(90deg,var(--acc),var(--acc3));border-radius:2px;margin:0 auto}

/* NEWS */
.news-bg{background:var(--bg2)}
.news-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:18px;max-width:1100px;margin:0 auto}
.nc{background:var(--surf);border:1px solid var(--bd);border-radius:18px;overflow:hidden;transition:.3s;cursor:pointer}
.nc:hover{transform:translateY(-4px);border-color:var(--acc);box-shadow:0 16px 40px rgba(0,0,0,.3)}
.nc.feat{grid-row:span 2}
.nc-img{width:100%;display:flex;align-items:center;justify-content:center;height:200px;font-size:60px}
.nc.feat .nc-img{height:290px;font-size:70px}
.nc-body{padding:18px}
.nc-cat{font-size:9px;font-family:'Rajdhani',sans-serif;letter-spacing:2px;color:var(--acc);font-weight:700;text-transform:uppercase;margin-bottom:7px}
.nc-title{font-size:15px;font-weight:700;line-height:1.6;color:var(--tx);margin-bottom:9px}
.nc.feat .nc-title{font-size:19px}
.nc-meta{font-size:11px;color:var(--tx3);display:flex;gap:12px}
.nc-src{font-size:10px;color:var(--acc3);margin-top:6px;display:block}

/* CATEGORIES */
.cats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;max-width:1100px;margin:0 auto}
.cat-c{background:var(--surf);border:1px solid var(--bd);border-radius:18px;padding:24px 16px;text-align:center;cursor:pointer;transition:.3s}
.cat-c:hover{border-color:var(--acc);transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.25)}
.cat-ic{font-size:32px;margin-bottom:12px;display:block}
.cat-nm{font-size:13px;font-weight:700;color:var(--tx);margin-bottom:3px}
.cat-ct{font-size:10px;color:var(--tx3);font-family:'Rajdhani',sans-serif}

/* VIDEOS */
.vid-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;max-width:1100px;margin:0 auto}
.vc{background:var(--surf);border:1px solid var(--bd);border-radius:18px;overflow:hidden;cursor:pointer;transition:.3s}
.vc:hover{transform:translateY(-4px);border-color:var(--acc2)}
.vt{position:relative;height:170px;background:var(--surf2);display:flex;align-items:center;justify-content:center}
.vp{width:50px;height:50px;border-radius:50%;background:rgba(255,60,110,.9);display:flex;align-items:center;justify-content:center;font-size:18px;transition:.3s;box-shadow:0 0 24px rgba(255,60,110,.4)}
.vc:hover .vp{transform:scale(1.15)}
.vd{position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,.75);color:#fff;font-family:'Rajdhani',sans-serif;font-size:10px;padding:2px 7px;border-radius:4px;letter-spacing:1px}
.vb{padding:14px}
.vb-t{font-size:13px;font-weight:700;color:var(--tx);line-height:1.6;margin-bottom:7px}
.vb-m{font-size:10px;color:var(--tx3);display:flex;gap:10px}

/* AI */
.ai-wrap{max-width:780px;margin:0 auto;background:var(--surf);border:1px solid var(--bd);border-radius:18px;overflow:hidden;box-shadow:0 16px 50px rgba(0,0,0,.35)}
.ai-hd{background:linear-gradient(135deg,var(--surf2),var(--surf));padding:18px 22px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:10px}
.ai-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--acc3));display:flex;align-items:center;justify-content:center;font-size:18px}
.ai-ht h3{font-size:15px;color:var(--tx);margin-bottom:2px}
.ai-ht p{font-size:11px;color:var(--acc3)}
.ai-dot{width:7px;height:7px;background:var(--acc3);border-radius:50%;margin-right:auto;animation:pu 2s ease-in-out infinite}
@keyframes pu{0%,100%{opacity:1}50%{opacity:.4}}
.ai-msgs{padding:22px;min-height:260px;max-height:380px;overflow-y:auto;display:flex;flex-direction:column;gap:14px}
.msg{display:flex;gap:9px;animation:fu .4s ease}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.mb{max-width:76%;padding:11px 15px;border-radius:14px;font-size:13px;line-height:1.75}
.msg.ai .mb{background:var(--surf2);border:1px solid var(--bd);color:var(--tx);border-radius:4px 14px 14px 14px}
.msg.user .mb{background:linear-gradient(135deg,var(--acc),#0055bb);color:#fff;border-radius:14px 4px 14px 14px}
.mi{font-size:20px;flex-shrink:0;margin-top:3px}
.dots span{display:inline-block;width:5px;height:5px;background:var(--acc);border-radius:50%;margin:0 2px;animation:dt 1.4s ease-in-out infinite}
.dots span:nth-child(2){animation-delay:.2s}.dots span:nth-child(3){animation-delay:.4s}
@keyframes dt{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.ai-chips{padding:0 22px 14px;display:flex;gap:7px;flex-wrap:wrap}
.chip{background:var(--surf2);border:1px solid var(--bd);color:var(--tx2);font-size:11px;padding:5px 12px;border-radius:18px;cursor:pointer;transition:.3s;font-family:'Cairo',sans-serif}
.chip:hover{border-color:var(--acc);color:var(--acc);background:rgba(0,180,255,.06)}
.ai-inp-row{padding:14px 22px;border-top:1px solid var(--bd);display:flex;gap:10px;align-items:center}
.ai-inp{flex:1;background:var(--surf2);border:1px solid var(--bd);border-radius:28px;padding:11px 18px;color:var(--tx);font-family:'Cairo',sans-serif;font-size:13px;outline:none;transition:.3s}
.ai-inp:focus{border-color:var(--acc)}
.ai-inp::placeholder{color:var(--tx3)}
.ai-send{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--acc),#0055bb);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:.3s;box-shadow:0 3px 12px var(--glow);flex-shrink:0}
.ai-send:hover{transform:scale(1.1)}

/* CONTACT */
.cc{max-width:580px;margin:0 auto;background:var(--surf);border:1px solid var(--bd);border-radius:18px;padding:44px 36px;text-align:center;position:relative;overflow:hidden}
.cp{font-family:'Rajdhani',sans-serif;font-size:38px;font-weight:700;color:var(--acc);margin:18px 0;letter-spacing:3px;display:block;text-decoration:none}
.soc-row{display:flex;justify-content:center;gap:12px;margin-top:26px;flex-wrap:wrap}
.sb{width:44px;height:44px;border-radius:50%;border:1px solid var(--bd);background:var(--surf2);display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:.3s;text-decoration:none;color:var(--tx2)}
.sb:hover{border-color:var(--acc);transform:translateY(-3px)}

/* FOOTER */
footer{background:var(--bg);border-top:1px solid var(--bd);padding:44px 28px 26px}
.ft{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:36px;margin-bottom:36px}
.fb h3{font-family:'Rajdhani',sans-serif;font-size:22px;color:var(--acc);letter-spacing:3px;margin-bottom:10px}
.fb p{color:var(--tx3);font-size:13px;line-height:1.8}
.fc h4{color:var(--tx);font-size:14px;margin-bottom:14px;font-weight:700}
.fc ul{list-style:none}
.fc ul li{margin-bottom:9px}
.fc ul a{color:var(--tx3);text-decoration:none;font-size:12px;transition:.3s;cursor:pointer}
.fc ul a:hover{color:var(--acc)}
.fb-bot{border-top:1px solid var(--bd);padding-top:22px;display:flex;justify-content:space-between;align-items:center;color:var(--tx3);font-size:11px}

/* FLOAT */
.float-ai{position:fixed;bottom:26px;left:26px;z-index:998}
.fa-btn{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--acc),#0055bb);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 5px 26px var(--glow);animation:fb 3s ease-in-out infinite}
@keyframes fb{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.fa-btn:hover{transform:scale(1.1)!important}
.fa-badge{position:absolute;top:-3px;right:-3px;width:16px;height:16px;background:var(--acc2);border-radius:50%;font-size:9px;color:#fff;font-weight:700;display:flex;align-items:center;justify-content:center;border:2px solid var(--bg)}
.news-loading{text-align:center;color:var(--tx2);padding:40px;font-size:14px;grid-column:1/-1}

@media(max-width:700px){
  .nav-links{display:none}
  .news-grid{grid-template-columns:1fr}
  .nc.feat{grid-row:auto}
  .stats-bar{grid-template-columns:repeat(2,1fr)}
  .ft{grid-template-columns:1fr}
}
</style>
</head>
