  document.querySelectorAll('.page').forEach(pg=>pg.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('on'));
  const nl=document.getElementById('nl-'+p);
  if(nl) nl.classList.add('on');
  window.scrollTo({top:0,behavior:'smooth'});
  if(p==='news') renderAllNews('all');
}

// ===== NEWS RENDER =====
function newsCard(item, featured){
  return `<div class="nc${featured?' feat':''}" onclick="window.open('${item.url}','_blank')" title="${item.title}">
    <div class="nc-img" style="background:linear-gradient(135deg,${item.bg},#050a0f);height:${featured?'290':'200'}px;font-size:${featured?'72':'55'}px">${item.em}</div>
    <div class="nc-body">
      <div class="nc-cat">${item.cat}</div>
      <h3 class="nc-title">${item.title}</h3>
      <div class="nc-meta"><span>🕐 ${item.time}</span><span>👁 ${item.views}</span></div>
      <span class="nc-src">↗ اقرأ المزيد على المصدر</span>
    </div>
  </div>`;
}

// Home news (featured layout)
(function(){
  const g=document.getElementById('homeNews');
  if(!g)return;
  g.innerHTML=newsCard(NEWS[0],true)+newsCard(NEWS[1],false)+newsCard(NEWS[2],false);
})();

// All news page
function renderAllNews(cat){
  const g=document.getElementById('allNewsGrid');
  if(!g)return;
  const filtered=cat==='all'?NEWS:NEWS.filter(n=>n.cat===cat);
  g.innerHTML=filtered.map(n=>newsCard(n,false)).join('');
}

function filterNews(cat,btn){
  document.querySelectorAll('#catFilters .chip').forEach(b=>{
    b.style.background='';b.style.color='';b.style.borderColor='';
  });
  btn.style.background='var(--acc)';btn.style.color='#000';btn.style.borderColor='var(--acc)';
  renderAllNews(cat);
}

function goToNewsCategory(cat){
  showPage('news');
  setTimeout(()=>{
    const btns=document.querySelectorAll('#catFilters .chip');
    btns.forEach(b=>{
      b.style.background='';b.style.color='';b.style.borderColor='';
      if(b.textContent.includes(cat)){
        b.style.background='var(--acc)';b.style.color='#000';b.style.borderColor='var(--acc)';
      }
    });
    renderAllNews(cat);
  },80);
}

// ===== AI =====
const SYS='أنت مساعد ذكي لمنصة Digital Eye الإعلامية الجزائرية. اسمك مساعد Digital Eye. تتحدث بثلاث لغات حسب لغة السؤال. تخصصك الأخبار والسياسة والاقتصاد والرياضة والتكنولوجيا والأحداث الجزائرية والعربية والدولية. ردودك موجزة ومهنية.';

async function askAI(txt){
  if(!txt||!txt.trim())return;
  const msgs=document.getElementById('aiMsgs');
  msgs.innerHTML+=`<div class="msg user"><span class="mi">👤</span><div class="mb">${txt}</div></div>`;
  const tid='t'+Date.now();
  msgs.innerHTML+=`<div class="msg ai" id="${tid}"><span class="mi">🤖</span><div class="mb"><div class="dots"><span></span><span></span><span></span></div></div></div>`;
  msgs.scrollTop=msgs.scrollHeight;
  aiHistory.push({role:'user',content:txt});
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:SYS,messages:aiHistory})
    });
    const data=await res.json();
    const reply=data.content?.[0]?.text||'عذراً، حدث خطأ. حاول مرة أخرى.';
    document.getElementById(tid)?.remove();
    aiHistory.push({role:'assistant',content:reply});
    msgs.innerHTML+=`<div class="msg ai" style="animation:fu .4s ease"><span class="mi">🤖</span><div class="mb">${reply.replace(/\n/g,'<br>')}</div></div>`;
  }catch(e){
    document.getElementById(tid)?.remove();
    msgs.innerHTML+=`<div class="msg ai"><span class="mi">🤖</span><div class="mb">⚠️ تأكد من إضافة مفتاح Anthropic API في الكود (السطر الخاص بـ headers).</div></div>`;
  }
  msgs.scrollTop=msgs.scrollHeight;
}

function sendMsg(){
  const inp=document.getElementById('aiInp');
  const v=inp.value.trim();
  if(!v)return;
  inp.value='';
  askAI(v);
}
